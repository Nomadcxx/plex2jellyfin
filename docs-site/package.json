{
  "name": "docs-site",
  "version": "0.0.3",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "dev": "next dev",
    "start": "serve out",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
