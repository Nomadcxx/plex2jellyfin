# Plex2Jellyfin Configuration
# Location: ~/.config/plex2jellyfin/config.toml
#
# This is a starter template. For a schema-complete file with current defaults,
# run: plex2jellyfin config init
# Guide: https://nomadcxx.github.io/plex2jellyfin/docs/reference/configuration/

# Managed by setup wizards (web / CLI / TUI).
[setup]
version = 1
completed = false

# Directories to watch for new media files
[watch]
movies = ["/path/to/downloads/movies"]
tv = ["/path/to/downloads/tv"]

# Destination Jellyfin library directories
[libraries]
movies = ["/path/to/jellyfin/Movies"]
tv = ["/path/to/jellyfin/TV Shows"]

# Daemon settings (daemon.enabled defaults to false until a wizard activates it)
[daemon]
enabled = true
scan_frequency = "5m"
health_addr = ":8686"

# General options
# dry_run is ignored by plex2jellyfin-daemon (always organizes for real).
[options]
dry_run = false
verify_checksums = false
delete_source = true

# Sonarr integration (for TV shows)
# Get API key from: Sonarr -> Settings -> General -> API Key
[sonarr]
enabled = false
url = "http://localhost:8989"
api_key = ""
notify_on_import = true

# Radarr integration (for movies)
# Get API key from: Radarr -> Settings -> General -> API Key
[radarr]
enabled = false
url = "http://localhost:7878"
api_key = ""
notify_on_import = true

# File permissions (optional, bare metal only — no effect in Docker)
# Leave user/group empty to preserve source ownership.
[permissions]
# user = "jellyfin"
# group = "media"
# file_mode = "0664"
# dir_mode = "0775"

# Optional Ollama assist for low-confidence / obfuscated names.
# Defaults match DefaultConfig; any valid Ollama model name works.
[ai]
enabled = false
ollama_endpoint = "http://localhost:11434"
model = "qwen2.5vl:7b"
# fallback_model = ""
# cloud_model = "nemotron-3-nano:30b-cloud"
confidence_threshold = 0.8
auto_trigger_threshold = 0.6

[jellyfin]
# enabled = true
# url = "http://localhost:8096"
# api_key = "..."
# webhook_secret = "..."
# plugin_shared_secret = "..."   # usually same as webhook_secret
# plugin_enabled = true
# plugin_daemon_url = "http://192.168.1.10:5522"  # never localhost from a container

# Path mappings translate between Jellyfin's view of a media file (typically
# a container-internal path) and the daemon's view (the host filesystem
# path). Required whenever Jellyfin runs in a container with bind mounts
# whose roots differ from the daemon's. Without these, organizes still
# succeed but webhooks never match parse_decisions (jellyfin_item_id stays
# empty) and PASS/DRIFT/FAIL labeling never runs; the sweeper eventually
# marks uncorrelated rows FAIL. Mappings are applied longest-prefix first.
# Full guide: https://nomadcxx.github.io/plex2jellyfin/docs/getting-started/path-mappings/
#
# [[jellyfin.path_mappings]]
# jellyfin = "/tv5"
# daemon   = "/mnt/STORAGE5/TVSHOWS"
#
# [[jellyfin.path_mappings]]
# jellyfin = "/movies"
# daemon   = "/mnt/STORAGE2/MOVIES"
